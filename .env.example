# Backend
APP_ENV=local
APP_NAME=store-advisor
API_HOST=127.0.0.1
API_PORT=8000

# Map provider
AMAP_API_KEY=replace_with_your_amap_web_service_key
DEFAULT_SEARCH_RADIUS_METERS=1000

# LLM provider
LLM_PROVIDER=qwen
LLM_API_KEY=replace_with_your_llm_api_key
LLM_MODEL=qwen-plus

# Database
DATABASE_URL=sqlite:///./store_advisor.db

